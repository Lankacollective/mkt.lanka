# ============================================================
# LANKA CORE API — Variables de Entorno
# Renombra este archivo a .env (sin prefijo)
# NUNCA subas este archivo a GitHub — ya está en .gitignore
# En Vercel, copia cada variable en Settings > Environment Variables
# ============================================================

PORT=3000

# Orígenes permitidos (CORS) — separados por coma, sin espacios
# En producción cambia localhost por tu dominio real
# Ej: https://lanka.vercel.app,https://tudominio.com
ORIGENES_PERMITIDOS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# API Key interna — la que usas en el header x-lanka-key desde el frontend
# Cámbiala por algo más seguro antes de producción
API_KEY_INTERNA=lanka_dev_key_super_secreta

# ── META / FACEBOOK ADS ──────────────────────────────────────
# Consíguelos en: https://developers.facebook.com/apps/
# 1. Crea una App de tipo "Business"
# 2. Agrega el producto "Marketing API"
# 3. App ID y App Secret están en Configuración > Básica
META_APP_ID=aqui_va_tu_id_de_meta
META_APP_SECRET=aqui_va_tu_secreto_de_meta

# URL de callback OAuth — en Vercel cambia localhost por tu URL de Vercel
# Ej: https://lanka-api.vercel.app/auth/meta/callback
# Esta misma URL debe estar en Facebook App > OAuth Redirect URIs
REDIRECT_URI=http://localhost:3000/auth/meta/callback
